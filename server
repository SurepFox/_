local function CreateEvent()
	FluffyEvent=ins("RemoteEvent")
	FluffyEvent.Name=""

	FluffyEvent.AncestryChanged:Connect(function(_,Prnt)
		if not Prnt or Prnt~=Players then
			CreateEvent()
			Reset()
		end
	end)

	if load then
		FluffyEvent.Parent=Players
	end
	_G.FluffyEvent=FluffyEvent
end

