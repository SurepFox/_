for _,obj in pairs(Objects) do
	obj.Parent = script
end

local ins=Instance.new
local cf=CFrame.new
local sin=math.sin

local oangles=CFrame.Angles
local angles=function(x,y,z)
	return CFrame.Angles(math.rad(x),math.rad(y),math.rad(z))
end

local Light=game:GetService("Lighting")
local Repl=game:GetService("ReplicatedStorage")
local Plrs=game:GetService("Players")
Light.GeographicLatitude=219
local Grad=ins("ColorGradingEffect",Light)
Grad.TonemapperPreset="Retro"


local SavesSkins={}

function PlrSpawn(Plr)
	if Plr.Character.Humanoid.RigType==Enum.HumanoidRigType.R6 then return end

	local UserId=Plr.UserId

	if not SavesSkins[UserId] then
		local Create=Plrs:GetHumanoidDescriptionFromUserIdAsync(UserId)
		local Dummy=script.R6:Clone()
		Dummy.Parent=script
		Dummy.Name=Plr.Name
		Dummy.Humanoid:ApplyDescriptionReset(Create)
		Dummy.Head.face.Parent=Dummy
		Dummy.Head.Mesh.Parent=Dummy
		Dummy.Head:Destroy()
		SavesSkins[UserId]=Dummy
	end
	
	repeat
		task.wait()
	until Plr.Character and SavesSkins[UserId]
		
	local CF=Plr.Character:WaitForChild("HumanoidRootPart").CFrame
	local PlrR6=script.R6PlrRig:Clone()

	Plr.Character=PlrR6
	Plr.Character.Parent=workspace
	Plr.Character:PivotTo(CF)
	
	local Character=Plr.Character
	local Char=SavesSkins[UserId]
	
	for _,v in next,Character:GetChildren() do
		if v:IsA("CharacterAppearance") or v:IsA("Accessory") then
			v:Destroy()
		end
	end

	for _,v in next,Char:GetChildren() do
		if v:IsA("CharacterAppearance") or v:IsA("Accessory") then
			v:Clone().Parent=Character
		elseif v.Name=="face" or v.Name=="Mesh" then
			v:Clone().Parent=Character.Head
		end
	end
	
end

Plrs.PlayerAdded:Connect(function(Plr)
	Plr.CharacterAdded:Connect(function()
		PlrSpawn(Plr)
	end)
end)

for _,v in next,Plrs:GetPlayers() do
	v.CharacterAdded:Connect(function()
		PlrSpawn(v)
	end)
	v:LoadCharacterAsync()
end

function animateCharacter(char)
	if not char or not char:FindFirstChild("Torso") or not char:FindFirstChild("HumanoidRootPart") then
		return
	end

	function createWeld(jointName, parentObj, origParent)
		local original = (origParent or char.Torso)[jointName]
		local weld = Instance.new("Weld")
		weld.Name = jointName
		weld.Part0 = original.Part0
		weld.Part1 = original.Part1
		weld.C0 = original.C0
		weld.C1 = original.C1
		weld.Parent = parentObj
		return weld, original.C0
	end

	local rs,  rsC0  = createWeld("Right Shoulder",  char.Torso)
	local ls,  lsC0  = createWeld("Left Shoulder",   char.Torso)
	local n,   nC0   = createWeld("Neck",            char.Torso)
	local lh,  lhC0  = createWeld("Left Hip",        char.Torso)
	local rh,  rhC0  = createWeld("Right Hip",       char.Torso)
	local rj,  rjC0  = createWeld("RootJoint",       char.Torso, char.HumanoidRootPart)

	return rs,  rsC0,ls,  lsC0,n,   nC0,lh,  lhC0,rh,  rhC0,rj,  rjC0
end

function create(v)
	local m=script.Model:Clone()
	for _,x in next,m:GetChildren() do
		x.Color=v.Torso.Color
		x.Color=v.Torso.Color
	end
	local w=ins("Weld",m)
	w.Part0=m.PrimaryPart
	w.Part1=v.Torso
	m.Parent=v
end

Plrs.RespawnTime=.8

for _,v in next,workspace.Bots:GetChildren() do
	local Promt=ins("ProximityPrompt",v.HumanoidRootPart)
	Promt.HoldDuration=.1
	Promt.RequiresLineOfSight=false
	Promt.ActionText="Play"
	
	create(v)
	
	Promt.Triggered:Connect(function(Plr)
		Promt.Enabled=false
		local Char=Plr.Character
		Char.Humanoid.AutoRotate=false
		Char.HumanoidRootPart.Anchored=true
		Char.HumanoidRootPart.CFrame=v.HumanoidRootPart.CFrame
		
		local Sine=0
		local Change=.07
		local rs,  rsC0,ls,  lsC0,n,   nC0,lh,  lhC0,rh,  rhC0,rj,  rjC0=animateCharacter(v)
		local rs2,  rs2C0,ls2,  ls2C0,n2,   n2C0,lh2,  lh2C0,rh2,  rh2C0,rj2,  rj2C0=animateCharacter(Char)
		
		create(Char)
		
		while game:GetService("RunService").Heartbeat:Wait() do
			if not Char.Parent then
				break
			end
			Sine = Sine + 1
			local sw=sin(Sine/8)*Change
			ls.C0 = ls.C0:Lerp(lsC0*cf(-0.372, -0.218, 0) * angles(11.335, -18.473, -57.679)* oangles(0, 0, sw), 1)
			lh.C0 = lh.C0:Lerp(lhC0*cf(0, 0, 0) * angles(-13.494, 3, -12.337)* oangles(0, 0, sw*2), 1)
			rj.C0 = rj.C0:Lerp(rjC0*cf(0, -1, -0.137) * angles(16.537, 0, 0)*cf(0,-sw,sw)* oangles(-sw, 0, 0), 1)
			n.C0 = n.C0:Lerp(nC0*cf(0, 0, 0) * angles(6.916, 0, 0)* oangles(sw, 0, 0), 1)
			rh.C0 = rh.C0:Lerp(rhC0*cf(0, 0, 0) * angles(-18, -4, 12)* oangles(0, 0, -sw*2), 1)
			rs.C0 = rs.C0:Lerp(rsC0*cf(0.372, -0.218, 0) * angles(9.818, 16.162, 58.131)* oangles(0, 0, -sw), 1)

			ls2.C0 = ls2.C0:Lerp(ls2C0*cf(-0.194, 0.415, 0) * angles(0, 0, 150.971)* oangles(0, 0, sw), 1)
			lh2.C0 = lh2.C0:Lerp(lh2C0*cf(0, -0, -0) * angles(3.874, 18.274, -102.188)* oangles(0, 0, -sw), 1)
			rj2.C0 = rj2.C0:Lerp(rj2C0*cf(0, -3.217, -1.789) * angles(125.448, 0, 0)*cf(0,sw,sw), 1)
			n2.C0 = n2.C0:Lerp(n2C0*cf(0, 0, 0) * angles(-14, -2, -81.948)* oangles(0, -sw*2, 0), 1)
			rh2.C0 = rh2.C0:Lerp(rh2C0*cf(-0, -0, 0) * angles(2.542, -12.229, 101.836)* oangles(0, 0, sw), 1)
			rs2.C0 = rs2.C0:Lerp(rs2C0*cf(0.194, 0.415, 0) * angles(0, 0, -150.971)* oangles(0, 0, -sw), 1)
		end
		
		rs:Destroy()
		ls:Destroy()
		rj:Destroy()
		n:Destroy()
		rh:Destroy()
		lh:Destroy()
		
		Promt.Enabled=true
		
	end)

end
